{
  "name": "kline-similarity-tool",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "node scripts/build.cjs",
    "build:cf": "npm test && node scripts/build.cjs --stamp && node scripts/policy-check.cjs --require-stamp",
